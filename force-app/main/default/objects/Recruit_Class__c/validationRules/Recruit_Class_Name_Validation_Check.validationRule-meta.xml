<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Recruit_Class_Name_Validation_Check</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(REGEX(Name, &quot;^[A-Z] [0-9]{4}$&quot;))</errorConditionFormula>
    <errorMessage>Please follow Naming Conversion as ex: &apos; A 2026 &apos;</errorMessage>
</ValidationRule>
